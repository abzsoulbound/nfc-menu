# Required: your Stripe platform secret key.
STRIPE_SECRET_KEY=sk_test_your_platform_secret_key_here

# Required: the public URL for this demo.
BASE_URL=http://localhost:3001

# Optional but recommended: the signing secret for /webhooks/stripe.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Optional: override the port if 3001 is busy.
PORT=3001
