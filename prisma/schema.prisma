generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NfcTag {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  assignment TableAssignment?
  sessions   Session[]
}

model TableAssignment {
  id        String   @id @default(uuid())
  tableNo   Int
  tagId     String   @unique
  tag       NfcTag   @relation(fields: [tagId], references: [id])
  createdAt DateTime @default(now())
  drafts    TableDraft[]
  tickets   KitchenTicket[]
}

model Session {
  id        String   @id @default(uuid())
  tagId     String
  tag       NfcTag   @relation(fields: [tagId], references: [id])
  createdAt DateTime @default(now())
  cart      SessionCart?
}

model SessionCart {
  id        String   @id @default(uuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String      @id @default(uuid())
  cartId   String
  cart     SessionCart @relation(fields: [cartId], references: [id])
  name     String
  quantity Int
}

model TableDraft {
  id        String   @id @default(uuid())
  tableId   String
  table     TableAssignment @relation(fields: [tableId], references: [id])
  createdAt DateTime @default(now())
  items     DraftItem[]
}

model DraftItem {
  id        String     @id @default(uuid())
  draftId  String
  draft    TableDraft @relation(fields: [draftId], references: [id])
  memberId Int
  name     String
  quantity Int
}

model KitchenTicket {
  id        String   @id @default(uuid())
  tableId   String
  table     TableAssignment @relation(fields: [tableId], references: [id])
  createdAt DateTime @default(now())
  readyAt   DateTime?
  items     TicketItem[]
}

model TicketItem {
  id        String         @id @default(uuid())
  ticketId String
  ticket   KitchenTicket @relation(fields: [ticketId], references: [id])
  name     String
  quantity Int
  station  String
}

model DeviceSession {
  id        String   @id @default(uuid())
  role      String
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  createdAt DateTime @default(now())
}
