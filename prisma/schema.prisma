generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum SessionStatus {
  ACTIVE
  PAID
  CLOSED
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Station {
  KITCHEN
  BAR
}

model Restaurant {
  id               String            @id
  slug             String            @unique
  name             String
  logoUrl          String?
  primaryColor     String?
  secondaryColor   String?
  domain           String?           @unique
  vatRate          Float             @default(0.2)
  serviceCharge    Float             @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  nfcTags          NfcTag[]
  tables           Table[]
  tableAssignments TableAssignment[]
  sessions         Session[]
  sessionCarts     SessionCart[]
  cartItems        CartItem[]
  tableDrafts      TableDraft[]
  draftItems       DraftItem[]
  kitchenTickets   KitchenTicket[]
  ticketItems      TicketItem[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  orders           Order[]
  orderItems       OrderItem[]
  deviceSessions   DeviceSession[]
  staffUsers       StaffUser[]
  staffSessions    StaffSession[]
  loginAttempts    StaffLoginAttempt[]
  systemEvents     SystemEvent[]
}

model Table {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  tableNumber  Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, tableNumber])
  @@index([restaurantId])
}

model NfcTag {
  id           String     @id @default(uuid())
  tagId        String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime   @default(now())
  assignment   TableAssignment?
  sessions     Session[]

  @@unique([restaurantId, tagId])
  @@index([restaurantId])
  @@index([restaurantId, tagId])
  @@index([tagId])
}

model TableAssignment {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  tableNo      Int
  nfcTagId     String     @unique
  tagId        String
  tag          NfcTag     @relation(fields: [nfcTagId], references: [id])
  locked       Boolean    @default(false)
  closedAt     DateTime?
  closedPaid   Boolean?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  drafts       TableDraft[]
  tickets      KitchenTicket[]
  sessions     Session[]
  orders       Order[]

  @@unique([restaurantId, tagId])
  @@index([restaurantId])
  @@index([restaurantId, tableNo])
}

model Session {
  id             String           @id @default(uuid())
  restaurantId   String
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  nfcTagId       String
  tagId          String
  tag            NfcTag           @relation(fields: [nfcTagId], references: [id])
  tableId        String?
  table          TableAssignment? @relation(fields: [tableId], references: [id])
  openedAt       DateTime         @default(now())
  lastActivityAt DateTime         @default(now())
  status         SessionStatus    @default(ACTIVE)
  closedAt       DateTime?
  cart           SessionCart?
  orders         Order[]

  @@index([restaurantId])
  @@index([restaurantId, tagId, status])
  @@index([restaurantId, tagId, status, lastActivityAt(sort: Desc)])
  @@index([restaurantId, status, openedAt(sort: Desc)])
  @@index([nfcTagId, status])
  @@index([tableId, status])
}

model SessionCart {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  sessionId    String     @unique
  session      Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items        CartItem[]
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@index([restaurantId, sessionId])
}

model CartItem {
  id           String      @id @default(uuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  cartId       String
  cart         SessionCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItemId   String?
  menuItem     MenuItem?   @relation(fields: [menuItemId], references: [id])
  name         String
  quantity     Int
  unitPrice    Float
  vatRate      Float
  allergens    Json
  station      Station
  edits        Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([restaurantId])
  @@index([cartId])
  @@index([restaurantId, cartId])
}

model TableDraft {
  id           String          @id @default(uuid())
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id])
  tableId      String
  table        TableAssignment @relation(fields: [tableId], references: [id])
  createdAt    DateTime        @default(now())
  items        DraftItem[]

  @@index([restaurantId])
}

model DraftItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  draftId      String
  draft        TableDraft @relation(fields: [draftId], references: [id])
  memberId     Int
  name         String
  quantity     Int

  @@index([restaurantId])
}

model KitchenTicket {
  id           String          @id @default(uuid())
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id])
  orderId      String?
  order        Order?          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tableId      String?
  table        TableAssignment? @relation(fields: [tableId], references: [id])
  station      String
  status       OrderStatus     @default(PENDING)
  createdAt    DateTime        @default(now())
  readyAt      DateTime?
  completedAt  DateTime?
  items        TicketItem[]

  @@index([restaurantId])
  @@index([restaurantId, station, status, createdAt])
  @@index([orderId])
}

model TicketItem {
  id           String        @id @default(uuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  ticketId     String
  ticket       KitchenTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  orderItemId  String?
  orderItem    OrderItem?    @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  name         String
  quantity     Int
  station      String
  status       OrderStatus   @default(PENDING)
  createdAt    DateTime      @default(now())
  completedAt  DateTime?

  @@index([restaurantId])
  @@index([ticketId])
  @@index([orderItemId])
  @@index([restaurantId, station, status])
}

model MenuCategory {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  slug         String
  name         String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  items        MenuItem[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
}

model MenuItem {
  id           String       @id
  sku          String
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  categoryId   String
  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sortOrder    Int          @default(0)
  name         String
  description  String
  image        String?
  basePrice    Float
  vatRate      Float
  allergens    Json
  station      Station
  available    Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@unique([restaurantId, sku])
  @@index([restaurantId])
  @@index([categoryId, available])
}

model Order {
  id             String          @id @default(uuid())
  restaurantId   String
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  sessionId      String
  session        Session         @relation(fields: [sessionId], references: [id])
  tableId        String?
  table          TableAssignment? @relation(fields: [tableId], references: [id])
  clientRequestId String?
  targetStation  Station
  status         OrderStatus     @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  completedAt    DateTime?
  items          OrderItem[]
  tickets        KitchenTicket[]

  @@unique([restaurantId, clientRequestId])
  @@index([restaurantId])
  @@index([tableId, status, createdAt])
  @@index([targetStation, status, createdAt])
}

model OrderItem {
  id           String      @id @default(uuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  orderId      String
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String?
  menuItem     MenuItem?   @relation(fields: [menuItemId], references: [id])
  name         String
  quantity     Int
  unitPrice    Float
  vatRate      Float
  allergens    Json
  edits        Json?
  station      Station
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  completedAt  DateTime?
  ticketItems  TicketItem[]

  @@index([restaurantId])
  @@index([station, status])
}

model DeviceSession {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  role         String
  revoked      Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model StaffUser {
  id                String           @id @default(uuid())
  restaurantId      String
  restaurant        Restaurant       @relation(fields: [restaurantId], references: [id])
  name              String
  role              String
  passcodeHash      String?
  passcodeUpdatedAt DateTime?
  active            Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  sessions          StaffSession[]

  @@index([restaurantId, role])
  @@unique([restaurantId, name])
}

model StaffSession {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  staffUserId  String
  staffUser    StaffUser  @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  tokenHash    String
  createdAt    DateTime   @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  lastSeenAt   DateTime?
  ip           String?
  userAgent    String?
  deviceLabel  String?

  @@index([restaurantId, staffUserId])
  @@index([expiresAt])
  @@index([tokenHash])
}

model StaffLoginAttempt {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  identifier   String
  ip           String
  createdAt    DateTime   @default(now())
  success      Boolean

  @@index([restaurantId, identifier, ip, createdAt])
  @@index([createdAt])
}

model SystemEvent {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  type         String
  payload      Json
  actor        String?
  sessionId    String?
  tableId      String?
  orderId      String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([createdAt])
  @@index([type])
  @@index([sessionId])
  @@index([tableId])
  @@index([orderId])
}
