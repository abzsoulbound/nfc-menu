{
  "name": "nfc-pos",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "playwright:install": "playwright install chromium",
    "test:qa": "vitest run tests/qa",
    "qa:routes": "node scripts/qa-route-smoke.mjs",
    "test:watch": "vitest",
    "test:api": "vitest run tests/api",
    "qa:full": "npm run typecheck && npm run lint && npm run test:qa && npm run build && npm run qa:routes",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "~6.19.2",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "prisma": "~6.19.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
