{
  "name": "nfc-pos",
  "private": true,
  "engines": {
    "node": "20.x || 22.x"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/clean-next-dist.mjs",
    "build": "next build",
    "start": "next start",
    "demo:stripe:express": "node examples/stripe-connect-express-demo/server.js",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "playwright:install": "playwright install chromium",
    "test:qa": "vitest run tests/qa",
    "qa:prod:env": "node scripts/production-env-preflight.mjs",
    "qa:prod:schema:compat": "node scripts/prod-schema-compat.mjs",
    "qa:smoke:remote": "node scripts/remote-checkout-smoke.mjs",
    "qa:routes": "node scripts/qa-route-smoke.mjs",
    "qa:routes:prod": "node scripts/qa-route-smoke.mjs --env-file .env.neoncheck.production",
    "test:watch": "vitest",
    "test:api": "vitest run tests/api",
    "qa:full": "npm run typecheck && npm run lint && npm run test:qa && npm run build && npm run qa:routes",
    "qa:release": "node scripts/qa-release.mjs",
    "qa:release:prod": "node scripts/qa-release.mjs --env-file .env.neoncheck.production",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:reconcile": "node scripts/prisma-migration-history-reconcile.mjs"
  },
  "dependencies": {
    "@prisma/client": "~6.19.2",
    "@vercel/analytics": "^1.6.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^20.1.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "prisma": "~6.19.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
