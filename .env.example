DATABASE_URL=postgresql://user:pass@localhost:5432/nfc_pos
DEFAULT_RESTAURANT_SLUG=demo-template
SALES_DEMO_SLUG=sales-demo
STAFF_AUTH_SECRET=1111
WAITER_PASSCODES=1111,1112
KITCHEN_PASSCODES=2222
BAR_PASSCODES=3333
MANAGER_PASSCODES=4444
ADMIN_PASSCODES=9999
SYSTEM_AUTH_SECRET=changeme
# Required in production: use a dedicated long random secret for staff session tokens.
STAFF_SESSION_SECRET=
PAYMENT_MODE=SIMULATED
ALLOW_SIMULATED_PAYMENTS=true
PAYMENT_PROVIDER=STRIPE_CONNECT
# Preferred Stripe secret key variable for Connect + Billing service routes.
STRIPE_SECRET_KEY=
# Preferred Stripe publishable key variable for client checkout flows.
STRIPE_PUBLISHABLE_KEY=
PAYMENT_PROVIDER_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_OAUTH_REDIRECT_URI=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_SUBSCRIPTION_PRICE_ID=
# Optional one-off setup fee product price for initial restaurant onboarding.
STRIPE_SETUP_FEE_PRICE_ID=
ENABLE_DEMO_TOOLS=false
ENABLE_SETUP_V2=true
ENABLE_DURABLE_RUNTIME_REQUIRED=false
ENABLE_NAMED_STAFF_ACCOUNTS=true
ENABLE_EXTERNAL_PAYMENTS_REQUIRED=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_CUSTOMER_MINIMAL_MODE=true
NEXT_PUBLIC_BRAND_LOGO_URL=
NEXT_PUBLIC_BRAND_HERO_URL=
NEXT_PUBLIC_PLATFORM_NAME=NFC Ordering Platform
NEXT_PUBLIC_PLATFORM_MONOGRAM=NP
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_SUPPORT_HOURS=Mon-Fri, 09:00-17:00 GMT
NEXT_PUBLIC_SERVICE_REGION=United Kingdom

# Optional: dedicated keys for the isolated Stripe Connect sample at /connect-demo.
# If omitted, the sample falls back to PAYMENT_PROVIDER_SECRET / STRIPE_WEBHOOK_SECRET.
STRIPE_SAMPLE_SECRET_KEY=
STRIPE_SAMPLE_WEBHOOK_SECRET=
